# =============================================================================
# ENVIRONMENT VARIABLES CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED CONFIGURATION
# -----------------------------------------------------------------------------

# MongoDB connection string
# Format: mongodb://localhost:27017/blog-app
# Or use MongoDB Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/blog-app
DATABASE_URI=mongodb://127.0.0.1/your-database-name

# Payload CMS secret key - generate a strong random string
# Used for JWT tokens and encryption
PAYLOAD_SECRET=YOUR_SECRET_HERE

# -----------------------------------------------------------------------------
# LANGUAGE CONFIGURATION (Optional)
# -----------------------------------------------------------------------------

# Default language for frontend and CMS
# Supported values: 'en' (English), 'he' (Hebrew), 'hr' (Croatian), 'tr' (Turkish)
# Default: 'en'
NEXT_PUBLIC_DEFAULT_LANG=en

# Added by Payload
NEXT_PUBLIC_PAYLOAD_URL=http://example.com
#SERVER_URL for local development
NEXT_PUBLIC_URL=http://example.com
#Next.js public URL for frontend
NEXT_PUBLIC_SITE_URL=http://example.com
# Production URL (used by Vercel)
BLOB_READ_WRITE_TOKEN=your_blob_read_write_token_here
VERCEL_URL=https://example-vercel.app